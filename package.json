{
  "name": "vite-plugin-experimental-storybook-devtools",
  "type": "module",
  "version": "0.0.0",
  "description": "A Vite plugin for visual component highlighting and automatic Storybook story generation.",
  "author": "Yann Braga <yannbf@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/yannbf/vite-plugin-experimental-storybook-devtools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yannbf/vite-plugin-experimental-storybook-devtools.git"
  },
  "bugs": {
    "url": "https://github.com/yannbf/vite-plugin-experimental-storybook-devtools/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/frameworks/react/plugin.d.mts",
      "default": "./dist/frameworks/react/plugin.mjs"
    },
    "./vue": {
      "types": "./dist/frameworks/vue/plugin.d.mts",
      "default": "./dist/frameworks/vue/plugin.mjs"
    },
    "./package.json": "./package.json",
    "./client-component-highlighter/overlay": "./dist/client-component-highlighter/overlay.mjs",
    "./client-component-highlighter/listeners": "./dist/client-component-highlighter/listeners.mjs",
    "./client-component-highlighter/vite-devtools": "./dist/client-component-highlighter/vite-devtools.mjs",
    "./client-iframe": "./packages/client-iframe/dist/index.html"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "packages/client-iframe/dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run build:client-iframe && pnpm run build:plugin",
    "build:client-iframe": "cd packages/client-iframe && vite build",
    "build:plugin": "tsdown",
    "dev": "npm-run-all --parallel dev:client-iframe dev:plugin",
    "dev:client-iframe": "cd packages/client-iframe && vite",
    "dev:plugin": "tsdown --watch",
    "play": "vite",
    "test": "vitest",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "release": "bumpp && pnpm publish",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@babel/parser": "^7.28.6",
    "@babel/traverse": "^7.28.6",
    "@babel/types": "^7.28.6",
    "@playwright/test": "^1.57.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.0.3",
    "@vitejs/devtools": "0.0.0-alpha.32",
    "@vitejs/devtools-kit": "0.0.0-alpha.32",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/coverage-v8": "4.0.17",
    "@vue/compiler-sfc": "^3.5.28",
    "bumpp": "^10.3.2",
    "npm-run-all2": "catalog:",
    "pkg-pr-new": "^0.0.62",
    "playwright": "^1.57.0",
    "sirv": "catalog:",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0-beta.14",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@babel/generator": "^7.28.6",
    "@medv/finder": "^3.1.0",
    "@testing-library/dom": "^10.4.0",
    "dom-accessibility-api": "^0.6.3",
    "nanoevents": "^9.0.0",
    "react-element-to-jsx-string": "^15.0.0"
  }
}
